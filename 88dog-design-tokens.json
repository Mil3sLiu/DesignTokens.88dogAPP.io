{
  "color": {
    "primitive": {
      "neutral": {
        "n50": "#f7f8fa",
        "n100": "#f0f2f6",
        "n200": "#d8dce3",
        "n300": "#b8c0cc",
        "n400": "#9099a8",
        "n500": "#6b7380",
        "n600": "#4c525c",
        "n700": "#353940",
        "n800": "#242426",
        "n900": "#151414"
      },
      "brand": {
        "primary": "#face66",
        "success": "#4cc38a",
        "warning": "#f3b63f",
        "error": "#e86a6a",
        "info": "#5fa8ff"
      }
    },
    "semantic": {
      "text": {
        "primary": "{neutral.n100}",
        "secondary": "{neutral.n300}",
        "muted": "{neutral.n500}"
